import math

class Circle:
    def __init__(self, radius):
        self.radius = radius  # Викличе сеттер для перевірки

    @property
    def radius(self):
        return self._radius

    @radius.setter
    def radius(self, value):
        if value <= 0:
            raise ValueError("Радіус має бути додатним числом")
        self._radius = value

    @property
    def diameter(self):
        return self._radius * 2

    @property
    def area(self):
        return math.pi * (self._radius ** 2)

try:
    circle1 = Circle(5)
    print(circle1.radius, circle1.diameter, circle1.area)
except Exception as e:
    print(e)

try:
    circle2 = Circle(10)
    circle2.radius = -3
except Exception as e:
    print(e)

try:
    circle3 = Circle(7)
    circle3.radius = 2.5
    print(round(circle3.area, 2))
except Exception as e:
    print(e)
